{
  "collapse-filter": false,
  "search": "-path:docs -path:supabase -path:scripts -path:android -path:brand -path:screenshots -path:More",
  "showTags": true,
  "showAttachments": false,
  "hideUnresolved": false,
  "showOrphans": false,
  "collapse-color-groups": false,
  "colorGroups": [
    { "query": "tag:#core OR tag:#session OR tag:#kickoff", "color": { "a": 1, "rgb": 835807 } },
    { "query": "tag:#tech OR tag:#infrastructure OR tag:#features OR tag:#edge-function OR tag:#audio OR tag:#analytics OR tag:#monitoring OR tag:#pwa OR tag:#payments OR tag:#email OR tag:#android", "color": { "a": 1, "rgb": 15724527 } },
    { "query": "tag:#decisions OR tag:#adr", "color": { "a": 1, "rgb": 11141375 } },
    { "query": "tag:#reference OR tag:#marketing OR tag:#rules OR tag:#archive", "color": { "a": 1, "rgb": 16727450 } }
  ],
  "collapse-display": false,
  "showArrow": false,
  "textFadeMultiplier": 0,
  "nodeSizeMultiplier": 2.2,
  "lineSizeMultiplier": 1.0,
  "collapse-forces": false,
  "centerStrength": 0.3,
  "repelStrength": 14,
  "linkStrength": 0.8,
  "linkDistance": 100,
  "scale": 1,
  "close": false
}
