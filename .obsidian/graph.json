{
  "collapse-filter": false,
  "search": "path:.md -path:docs/ -path:supabase/ -path:scripts/ -path:android/ -path:brand/ -path:screenshots/ -path:More backgrounds/",
  "showTags": true,
  "showAttachments": false,
  "hideUnresolved": false,
  "showOrphans": true,
  "collapse-color-groups": false,
  "colorGroups": [
    { "query": "tag:#core", "color": { "a": 1, "rgb": 861951 } },
    { "query": "tag:#session", "color": { "a": 1, "rgb": 2874879 } },
    { "query": "tag:#reference", "color": { "a": 1, "rgb": 16744272 } },
    { "query": "tag:#marketing", "color": { "a": 1, "rgb": 10027263 } }
  ],
  "collapse-display": false,
  "showArrow": false,
  "textFadeMultiplier": 0.8,
  "nodeSizeMultiplier": 1.8,
  "lineSizeMultiplier": 1.5,
  "collapse-forces": false,
  "centerStrength": 0.5,
  "repelStrength": 10,
  "linkStrength": 1,
  "linkDistance": 80,
  "scale": 1,
  "close": false
}
